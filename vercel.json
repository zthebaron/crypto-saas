{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "cd client && npx vite build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://crypto-saasserver-production.up.railway.app/api/$1" },
    { "source": "/ws", "destination": "https://crypto-saasserver-production.up.railway.app/ws" },
    { "source": "/((?!api|assets|favicon).*)", "destination": "/index.html" }
  ]
}
